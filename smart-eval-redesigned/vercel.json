{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/server.ts"
    },
    {
      "src": "/public/(.*)",
      "dest": "src/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/public/$1"
    }
  ]
}
